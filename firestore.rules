rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny ALL
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // USERS (Phlebotomists and Admins)
    match /users/{userId} {
      // Admin can read all users. Phlebotomists can read their own data.
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn() && isAdmin();
      
      // Allow users to create their own profile upon registration
      allow create: if isSignedIn() && request.auth.uid == userId && incoming().uid == userId;
      // Allow user to update their name/phone, but not elevate role
      // Admin can update everything
      allow update: if isSignedIn() && (isAdmin() || (request.auth.uid == userId && incoming().role == existing().role));
    }

    // TESTS (Price List from CSV)
    match /tests/{testId} {
      // Anyone logged in can read the price list
      allow read: if isSignedIn();
      // Only admins can upload/edit the price list
      allow write: if isAdmin();
    }

    // ORDERS
    match /orders/{orderId} {
      // Admin can read all orders. Phleb can read their own orders.
      // Must include a filter in lists to prevent security rule warnings if not admin.

      allow get: if isSignedIn() && (isAdmin() || resource.data.phlebotomistId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.phlebotomistId == request.auth.uid);

      // Phlebotomist can create their own order, Admin can create for any
      allow create: if isSignedIn() && (isAdmin() || incoming().phlebotomistId == request.auth.uid);
      
      // Phlebotomist can update their own order, Admin can update any
      allow update: if isSignedIn() && (isAdmin() || (existing().phlebotomistId == request.auth.uid && incoming().phlebotomistId == request.auth.uid));
      
      allow delete: if isAdmin();
    }
  }
}
